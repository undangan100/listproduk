    },
    {
      id:5, name:'Penggaris Besi 30cm', icon:'📏', category:'Aksesori Meja',
      description:'Penggaris besi anti karat presisi tinggi, tahan lama untuk gambar teknik dan tulis.',
      features:['Bahan besi','30cm','Anti karat','Presisi tinggi'],
      price:15000, stock:60, badge:null,
      img:'', wa:'6281234567890',
      orderMessage:'Halo kak, saya mau order Penggaris Besi 30cm. Masih ada stok?'
    },
    {
      id:6, name:'Stapler Joyko No.10', icon:'📌', category:'Perlengkapan Kantor',
      description:'Stapler mini ringan untuk kebutuhan kantor dan rumah, muat staples No.10.',
      features:['Mini & ringan','No.10 staples','Anti macet','Kapasitas 20 lembar'],
      price:18000, stock:3, badge:null,
      img:'', wa:'6281234567890',
      orderMessage:'Halo kak, saya mau order Stapler Joyko. Masih ada stok?'
    }
  ]
};
// ══════════════════════════════════════════

// ── STATE ──
var isAdmin = false;
var activeFilter = 'Semua';
var searchQuery = '';
var extraProducts = [];
var overrides = {};
var pendingDelId = null;
var isEditMode = false;
var uploadedImgData = ''; // base64

// Load dari localStorage
(function(){
  try {
    var raw = localStorage.getItem('syakila_atk_v1');
    if(raw){ var d=JSON.parse(raw); extraProducts=d.extras||[]; overrides=d.overrides||{}; }
  } catch(e){}
})();

function saveLS(){
  try{ localStorage.setItem('syakila_atk_v1',JSON.stringify({extras:extraProducts,overrides:overrides})); }catch(e){}
}

function getAllProducts(){
  var defaults = CONFIG.defaultProducts.map(function(p){
    return overrides[p.id] ? Object.assign({},p,overrides[p.id]) : Object.assign({},p);
  });
  return defaults.concat(extraProducts);
}

function getFiltered(){
  var all = getAllProducts();
  if(activeFilter !== 'Semua') all = all.filter(function(p){ return p.category === activeFilter; });
  if(searchQuery) all = all.filter(function(p){
    var q = searchQuery.toLowerCase();
    return p.name.toLowerCase().includes(q) || p.description.toLowerCase().includes(q) || p.category.toLowerCase().includes(q);
  });
  return all;
}

// ── UTILS ──
function fmt(n){ return Number(n).toLocaleString('id-ID'); }
function tgLink(p){ return 'https://wa.me/'+(p.wa||CONFIG.waDefault)+'?text='+encodeURIComponent(p.orderMessage||'Halo, saya ingin order '+p.name); }
function stockStatus(s){
  s=parseInt(s)||0;
  if(s<=0) return {cls:'out-stock',label:'Habis'};
  if(s<=5) return {cls:'low-stock',label:'Stok '+s};
  return {cls:'in-stock',label:'Tersedia'};
}

function toast(msg, type){
  var t=document.getElementById('toast');
  t.textContent=msg; t.className='toast show'+(type?' '+type:'');
  clearTimeout(t._t); t._t=setTimeout(function(){t.className='toast';},3000);
}
function openModal(id){ document.getElementById(id).classList.add('open'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }

// ── STORE INFO ──
document.getElementById('siteName').textContent = CONFIG.storeName;
document.getElementById('footerName').textContent = CONFIG.storeName;
document.getElementById('footerWa').href = 'https://wa.me/'+CONFIG.waDefault;
document.getElementById('footerWa').textContent = '+'+CONFIG.waDefault;
document.getElementById('waFloat').onclick = function(){ window.open('https://wa.me/'+CONFIG.waDefault,'_blank'); };
document.title = CONFIG.storeName;

// ── RENDER STATS ──
function renderStats(){
  var all = getAllProducts();
  var cats = {};
  all.forEach(function(p){ cats[p.category]=1; });
  var total = all.reduce(function(s,p){ return s+(parseInt(p.stock)||0); },0);
  document.getElementById('statsRow').innerHTML =
    '<div class="stat-box"><span class="stat-val">'+all.length+'</span><span class="stat-lbl">Produk</span></div>'+
    '<div class="stat-box"><span class="stat-val">'+Object.keys(cats).length+'</span><span class="stat-lbl">Kategori</span></div>'+
    '<div class="stat-box"><span class="stat-val">'+total+'</span><span class="stat-lbl">Total Stok</span></div>'+
    '<div class="stat-box"><span class="stat-val">24/7</span><span class="stat-lbl">Layanan</span></div>';
}

// ── RENDER FILTER ──
function renderFilter(){
  var sec = document.getElementById('filterSection');
  sec.innerHTML='';
  CONFIG.categories.forEach(function(cat){
    var btn=document.createElement('button');
    btn.className='filter-chip'+(cat===activeFilter?' active':'');
    btn.textContent=cat;
    btn.onclick=function(){ activeFilter=cat; renderFilter(); renderGrid(); };
    sec.appendChild(btn);
  });
}

// ── RENDER GRID ──
function renderGrid(){
  var grid = document.getElementById('grid');
  var list = getFiltered();
  document.getElementById('prodCount').textContent = list.length+' item';
  grid.innerHTML='';

  if(list.length===0){
    grid.innerHTML='<div class="empty-state" style="grid-column:1/-1"><div class="e-icon">📭</div><p>Produk tidak ditemukan.<br/>Coba kata kunci lain atau tambah produk baru.</p></div>';
  }

  list.forEach(function(p,i){
    var isExtra = !CONFIG.defaultProducts.find(function(d){ return d.id===p.id; });
    var ss = stockStatus(p.stock);
    var card = document.createElement('div');
    card.className='pcard';
    card.style.animationDelay=(i*0.04)+'s';

    // Image area
    var imgHtml='';
    if(p.img){
      imgHtml='<div class="pcard-img"><img src="'+p.img+'" alt="'+p.name+'" loading="lazy"/></div>';
    } else {
      imgHtml='<div class="pcard-img no-img" style="font-size:3rem;display:flex;align-items:center;justify-content:center;">'+(p.icon||'📦')+'</div>';
    }

    var featsHtml = (p.features||[]).map(function(f){ return '<span class="feat-tag">'+f+'</span>'; }).join('');
    var badgeHtml = p.badge ? '<div class="pcard-badge">'+p.badge+'</div>' : '';
    var delLabel = isExtra ? '🗑️ Hapus' : '🔄 Reset';

    card.innerHTML =
      imgHtml +
      badgeHtml +
      '<div class="pcard-stock-badge '+ss.cls+'">'+ss.label+'</div>'+
      '<div class="pcard-body">'+
        '<div class="pcard-cat">'+p.category+'</div>'+
        '<div class="pcard-name">'+p.name+'</div>'+
        '<div class="pcard-desc">'+p.description+'</div>'+
        (featsHtml?'<div class="pcard-feats">'+featsHtml+'</div>':'')+
        '<div class="pcard-foot">'+
          '<div class="price-wrap">'+
            '<div class="price-lbl">Harga</div>'+
            '<div class="price-val"><small>Rp </small>'+fmt(p.price)+'</div>'+
          '</div>'+
          '<a href="'+tgLink(p)+'" target="_blank" class="order-btn">'+
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.122.556 4.112 1.528 5.837L.057 23.5l5.805-1.52A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.5-5.24-1.373l-.374-.222-3.896 1.02 1.04-3.797-.244-.39A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>'+
            'Order WA'+
          '</a>'+
        '</div>'+
      '</div>'+
      '<div class="admin-actions">'+
        '<button class="btn-edit" data-id="'+p.id+'">✏️ Edit</button>'+
        '<button class="btn-del" data-id="'+p.id+'" data-name="'+p.name+'" data-extra="'+(isExtra?'1':'0')+'">'+delLabel+'</button>'+
      '</div>';

    grid.appendChild(card);
  });

  // Add card
  var addCard=document.createElement('div');
  addCard.className='add-card';
  addCard.innerHTML='<div class="add-card-icon">➕</div><div class="add-card-text">Tambah Produk Baru</div>';
  addCard.onclick=function(){ openAddModal(); };
  grid.appendChild(addCard);

  // Events
  grid.querySelectorAll('.btn-edit').forEach(function(btn){
    btn.addEventListener('click',function(){ openEditModal(parseInt(btn.getAttribute('data-id'))); });
  });
  grid.querySelectorAll('.btn-del').forEach(function(btn){
    btn.addEventListener('click',function(){
      openDelModal(parseInt(btn.getAttribute('data-id')), btn.getAttribute('data-name'), btn.getAttribute('data-extra')==='1');
    });
  });
}

function renderAll(){ renderStats(); renderFilter(); renderGrid(); }

// ── IMAGE UPLOAD ──
document.getElementById('imgUploadArea').addEventListener('click',function(){ document.getElementById('fileInput').click(); });
document.getElementById('fileInput').addEventListener('change',function(e){
  var file=e.target.files[0];
  if(!file) return;
  if(file.size > 5*1024*1024){ toast('❌ Gambar terlalu besar (maks 5MB)','err'); return; }
  var reader=new FileReader();
  reader.onload=function(ev){
    uploadedImgData=ev.target.result;
    var prev=document.getElementById('imgPreview');
    prev.src=uploadedImgData; prev.style.display='block';
    document.getElementById('imgUploadArea').querySelector('.upload-icon').style.display='none';
    document.getElementById('imgUploadArea').querySelector('.upload-hint').style.display='none';
  };
  reader.readAsDataURL(file);
});

function resetImgUpload(){
  uploadedImgData='';
  document.getElementById('imgPreview').src=''; document.getElementById('imgPreview').style.display='none';
  document.getElementById('imgUploadArea').querySelector('.upload-icon').style.display='block';
  document.getElementById('imgUploadArea').querySelector('.upload-hint').style.display='block';
  document.getElementById('fileInput').value='';
}

// ── FORM MODAL ──
function clearForm(){
  ['fId','fName','fIcon','fDesc','fPrice','fStock','fFeats','fBadge','fWa'].forEach(function(id){ document.getElementById(id).value=''; });
  document.getElementById('fCat').value='Pensil & Pena';
  document.getElementById('fWa').value=CONFIG.waDefault;
  resetImgUpload();
}

function openAddModal(){
  isEditMode=false; clearForm();
  document.getElementById('prodModalTitle').textContent='➕ Tambah Produk';
  document.getElementById('prodModalSub').textContent='Isi data produk ATK baru.';
  document.getElementById('saveProd').textContent='💾 Simpan Produk';
  openModal('prodModal');
}

function openEditModal(id){
  var all=getAllProducts(), p=null;
  for(var i=0;i<all.length;i++){ if(all[i].id===id){p=all[i];break;} }
  if(!p) return;
  isEditMode=true; clearForm();
  document.getElementById('fId').value=p.id;
  document.getElementById('fName').value=p.name;
  document.getElementById('fIcon').value=p.icon||'';
  document.getElementById('fCat').value=p.category;
  document.getElementById('fDesc').value=p.description;
  document.getElementById('fPrice').value=p.price;
  document.getElementById('fStock').value=p.stock||0;
  document.getElementById('fFeats').value=(p.features||[]).join(', ');
  document.getElementById('fBadge').value=p.badge||'';
  document.getElementById('fWa').value=p.wa||CONFIG.waDefault;
  if(p.img){
    uploadedImgData=p.img;
    var prev=document.getElementById('imgPreview');
    prev.src=p.img; prev.style.display='block';
    document.getElementById('imgUploadArea').querySelector('.upload-icon').style.display='none';
    document.getElementById('imgUploadArea').querySelector('.upload-hint').style.display='none';
  }
  document.getElementById('prodModalTitle').textContent='✏️ Edit: '+p.name;
  document.getElementById('prodModalSub').textContent='Ubah data produk lalu simpan.';
  document.getElementById('saveProd').textContent='💾 Simpan Perubahan';
  openModal('prodModal');
}

function openDelModal(id, name, isExtra){
  pendingDelId=id;
  document.getElementById('delSub').innerHTML='Produk <strong>'+name+'</strong> akan '+(isExtra?'dihapus permanen.':'direset ke data awal.');
  openModal('delModal');
}

// SAVE
document.getElementById('saveProd').addEventListener('click',function(){
  var name=document.getElementById('fName').value.trim();
  var desc=document.getElementById('fDesc').value.trim();
  var price=parseInt(document.getElementById('fPrice').value)||0;
  if(!name||!desc){ toast('❌ Nama & deskripsi wajib diisi!','err'); return; }

  var icon=document.getElementById('fIcon').value.trim()||'📦';
  var cat=document.getElementById('fCat').value;
  var stock=parseInt(document.getElementById('fStock').value)||0;
  var featsRaw=document.getElementById('fFeats').value.trim();
  var features=featsRaw?featsRaw.split(',').map(function(f){return f.trim();}).filter(Boolean):[];
  var badge=document.getElementById('fBadge').value.trim()||null;
  var wa=document.getElementById('fWa').value.trim()||CONFIG.waDefault;
  var data={
    name:name,icon:icon,category:cat,description:desc,
    price:price,stock:stock,features:features,badge:badge,wa:wa,
    img:uploadedImgData,
    orderMessage:'Halo kak, saya mau order *'+name+'*. Masih ada stok? 🛒'
  };

  if(isEditMode){
    var id=parseInt(document.getElementById('fId').value);
    var isDef=CONFIG.defaultProducts.find(function(d){return d.id===id;});
    if(isDef){ overrides[id]=data; }
    else{
      for(var i=0;i<extraProducts.length;i++){
        if(extraProducts[i].id===id){extraProducts[i]=Object.assign({},extraProducts[i],data);break;}
      }
    }
    toast('✅ "'+name+'" berhasil diperbarui!','ok');
  } else {
    data.id=Date.now();
    extraProducts.push(data);
    toast('✅ "'+name+'" berhasil ditambahkan!','ok');
  }
  saveLS(); closeModal('prodModal'); activeFilter='Semua'; renderAll();
});

// DELETE
document.getElementById('confirmDel').addEventListener('click',function(){
  if(!pendingDelId) return;
  var isDef=CONFIG.defaultProducts.find(function(d){return d.id===pendingDelId;});
  if(isDef){ delete overrides[pendingDelId]; toast('🔄 Produk direset ke data awal','warn'); }
  else{ extraProducts=extraProducts.filter(function(p){return p.id!==pendingDelId;}); toast('🗑️ Produk berhasil dihapus'); }
  saveLS(); pendingDelId=null; closeModal('delModal'); renderAll();
});

// MODAL CLOSE
document.getElementById('cancelDel').addEventListener('click',function(){closeModal('delModal');});
document.getElementById('delModal').addEventListener('click',function(e){if(e.target.id==='delModal')closeModal('delModal');});
document.getElementById('closeProdModal').addEventListener('click',function(){closeModal('prodModal');});
document.getElementById('cancelProd').addEventListener('click',function(){closeModal('prodModal');});
document.getElementById('prodModal').addEventListener('click',function(e){if(e.target.id==='prodModal')closeModal('prodModal');});
document.getElementById('loginModal').addEventListener('click',function(e){if(e.target.id==='loginModal')closeModal('loginModal');});

// ── SEARCH ──
document.getElementById('searchInput').addEventListener('input',function(e){
  searchQuery=e.target.value.trim();
  renderGrid();
});

// ── ADMIN ──
function setAdmin(on){
  isAdmin=on;
  document.body.classList.toggle('admin-mode',on);
  document.getElementById('adminPill').classList.toggle('show',on);
  document.getElementById('fabLogin').textContent=on?'➕':'🔑';
  document.getElementById('fabLogin').title=on?'Tambah Produk':'Admin Login';
  renderGrid();
}

document.getElementById('fabLogin').addEventListener('click',function(){
  if(isAdmin){ openAddModal(); }
  else{ openModal('loginModal'); setTimeout(function(){document.getElementById('pwInput').focus();},150); }
});

function doLogin(){
  var pw=document.getElementById('pwInput').value;
  var err=document.getElementById('loginErr');
  if(pw===CONFIG.adminPassword){
    err.classList.remove('show');
    document.getElementById('pwInput').value='';
    closeModal('loginModal');
    setAdmin(true);
    toast('✅ Selamat datang, Admin!','ok');
  } else {
    err.classList.add('show');
    document.getElementById('pwInput').value='';
    document.getElementById('pwInput').focus();
  }
}

document.getElementById('loginBtn').addEventListener('click',doLogin);
document.getElementById('pwInput').addEventListener('keydown',function(e){if(e.key==='Enter')doLogin();});
document.getElementById('pwEye').addEventListener('click',function(){
  var i=document.getElementById('pwInput');
  i.type=i.type==='password'?'text':'password';
});
document.getElementById('logoutBtn').addEventListener('click',function(){ setAdmin(false); toast('👋 Keluar dari mode admin'); });

// ── BOOT ──
renderAll();
</script>
</body>
</html>
