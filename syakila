<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Syakila ATK Store</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --cream:#faf8f3;--warm:#f5f0e8;--brown:#2c1a0e;--brown2:#4a2f1a;--amber:#d4832a;--amber2:#f0a84b;
  --green:#2d5a3d;--green2:#3d7a54;--red:#c0392b;--muted:#8a7560;--border:#e8e0d0;
  --card:#ffffff;--shadow:0 4px 24px rgba(44,26,14,.1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--cream);color:var(--brown);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;}

/* NOISE TEXTURE */
body::before{content:'';position:fixed;inset:0;z-index:0;opacity:.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:200px 200px;pointer-events:none;}

/* HEADER */
.site-header{
  position:sticky;top:0;z-index:100;
  background:rgba(250,248,243,.92);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  padding:0 24px;
  display:flex;align-items:center;justify-content:space-between;
  height:68px;
}
.logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.logo-mark{width:40px;height:40px;background:var(--brown);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.logo-text{font-family:'Fraunces',serif;font-size:1.3rem;font-weight:700;color:var(--brown);line-height:1;}
.logo-sub{font-size:.65rem;color:var(--muted);font-weight:400;letter-spacing:2px;text-transform:uppercase;}
.header-right{display:flex;align-items:center;gap:12px;}
.admin-pill{display:none;align-items:center;gap:8px;background:var(--green);color:#fff;font-size:.75rem;font-weight:600;padding:6px 14px;border-radius:100px;letter-spacing:.5px;}
.admin-pill.show{display:inline-flex;}
.logout-btn{background:rgba(255,255,255,.2);border:none;color:#fff;font-size:.7rem;padding:3px 8px;border-radius:100px;cursor:pointer;transition:background .2s;}
.logout-btn:hover{background:rgba(255,255,255,.35);}
.fab-login{width:42px;height:42px;border-radius:50%;background:var(--brown);border:none;color:#fff;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;box-shadow:var(--shadow);}
.fab-login:hover{background:var(--amber);transform:scale(1.08);}

/* HERO */
.hero{
  position:relative;z-index:1;
  text-align:center;padding:80px 24px 60px;
  background:linear-gradient(180deg,var(--warm) 0%,var(--cream) 100%);
}
.hero-tag{display:inline-block;background:var(--amber2);color:var(--brown);font-size:.7rem;font-weight:700;letter-spacing:3px;padding:5px 16px;border-radius:100px;margin-bottom:20px;text-transform:uppercase;}
.hero h1{font-family:'Fraunces',serif;font-size:clamp(2.4rem,6vw,4.2rem);font-weight:900;line-height:1.08;color:var(--brown);margin-bottom:14px;}
.hero h1 em{font-style:italic;color:var(--amber);}
.hero p{color:var(--muted);font-size:1rem;max-width:480px;margin:0 auto 32px;line-height:1.7;}
.hero-cta{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--brown);color:#fff;text-decoration:none;
  font-weight:600;font-size:.9rem;padding:14px 28px;border-radius:12px;
  transition:all .2s;box-shadow:0 4px 20px rgba(44,26,14,.25);
}
.hero-cta:hover{background:var(--brown2);transform:translateY(-2px);box-shadow:0 8px 32px rgba(44,26,14,.3);}
.hero-cta svg{transition:transform .2s;}
.hero-cta:hover svg{transform:translateX(4px);}

/* STATS */
.stats-row{
  position:relative;z-index:1;
  display:flex;justify-content:center;gap:0;
  max-width:560px;margin:0 auto 48px;padding:0 24px;
}
.stat-box{flex:1;text-align:center;padding:18px 10px;border:1px solid var(--border);background:var(--card);}
.stat-box:first-child{border-radius:12px 0 0 12px;}
.stat-box:last-child{border-radius:0 12px 12px 0;}
.stat-box+.stat-box{border-left:none;}
.stat-val{font-family:'Fraunces',serif;font-size:1.6rem;font-weight:700;color:var(--brown);display:block;}
.stat-lbl{font-size:.68rem;color:var(--muted);font-weight:600;letter-spacing:1.5px;text-transform:uppercase;}

/* FILTERS */
.filter-section{position:relative;z-index:1;padding:0 24px 36px;display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}
.filter-chip{
  background:var(--card);border:1.5px solid var(--border);color:var(--muted);
  font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;
  padding:8px 18px;border-radius:100px;cursor:pointer;transition:all .2s;
}
.filter-chip:hover,.filter-chip.active{background:var(--brown);border-color:var(--brown);color:#fff;box-shadow:0 4px 16px rgba(44,26,14,.2);}

/* SEARCH */
.search-wrap{position:relative;z-index:1;max-width:400px;margin:0 auto 32px;padding:0 24px;}
.search-input{
  width:100%;background:var(--card);border:1.5px solid var(--border);
  color:var(--brown);font-family:'DM Sans',sans-serif;font-size:.9rem;
  padding:12px 18px 12px 44px;border-radius:50px;outline:none;transition:border-color .2s;
}
.search-input:focus{border-color:var(--amber);}
.search-icon{position:absolute;left:38px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:1rem;pointer-events:none;}

/* GRID */
.products-section{position:relative;z-index:1;max-width:1200px;margin:0 auto;padding:0 24px 80px;}
.section-title{font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;color:var(--brown);margin-bottom:24px;display:flex;align-items:center;gap:10px;}
.section-title span{font-family:'DM Sans',sans-serif;font-size:.78rem;font-weight:600;color:var(--muted);background:var(--warm);border:1px solid var(--border);padding:3px 10px;border-radius:100px;}

.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;}
@media(max-width:600px){.grid{grid-template-columns:repeat(2,1fr);gap:12px;}}
@media(max-width:400px){.grid{grid-template-columns:1fr;}}

/* PRODUCT CARD */
.pcard{
  background:var(--card);border:1.5px solid var(--border);border-radius:16px;
  overflow:hidden;transition:all .25s;animation:cardIn .4s ease both;
  display:flex;flex-direction:column;position:relative;
}
.pcard:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(44,26,14,.12);border-color:var(--amber2);}

.pcard-img{
  width:100%;aspect-ratio:4/3;object-fit:cover;background:var(--warm);
  display:flex;align-items:center;justify-content:center;font-size:3rem;
  flex-shrink:0;border-bottom:1px solid var(--border);
}
.pcard-img img{width:100%;height:100%;object-fit:cover;}
.pcard-img.no-img{background:linear-gradient(135deg,var(--warm),var(--border));}

.pcard-badge{
  position:absolute;top:10px;left:10px;
  background:var(--amber);color:var(--brown);
  font-size:.62rem;font-weight:700;padding:3px 9px;border-radius:100px;
  letter-spacing:.5px;text-transform:uppercase;
}
.pcard-stock-badge{
  position:absolute;top:10px;right:10px;
  font-size:.62rem;font-weight:700;padding:3px 9px;border-radius:100px;
}
.in-stock{background:var(--green);color:#fff;}
.low-stock{background:#f59e0b;color:#fff;}
.out-stock{background:var(--red);color:#fff;}

.pcard-body{padding:16px;flex:1;display:flex;flex-direction:column;}
.pcard-cat{font-size:.65rem;font-weight:700;letter-spacing:2px;color:var(--amber);text-transform:uppercase;margin-bottom:4px;}
.pcard-name{font-family:'Fraunces',serif;font-size:1.05rem;font-weight:700;color:var(--brown);margin-bottom:6px;line-height:1.3;}
.pcard-desc{font-size:.8rem;color:var(--muted);line-height:1.55;margin-bottom:10px;flex:1;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.pcard-feats{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:12px;}
.feat-tag{background:var(--warm);border:1px solid var(--border);color:var(--muted);font-size:.62rem;font-weight:600;padding:2px 7px;border-radius:4px;}
.pcard-foot{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:auto;border-top:1px solid var(--border);padding-top:12px;}
.price-wrap .price-lbl{font-size:.6rem;color:var(--muted);font-weight:600;letter-spacing:1px;text-transform:uppercase;}
.price-val{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:700;color:var(--brown);}
.price-val small{font-family:'DM Sans',sans-serif;font-size:.75rem;color:var(--muted);font-weight:400;}
.order-btn{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--green);color:#fff;text-decoration:none;
  font-size:.78rem;font-weight:700;padding:10px 14px;border-radius:8px;
  white-space:nowrap;transition:all .2s;border:none;cursor:pointer;
}
.order-btn:hover{background:var(--green2);transform:scale(1.04);}
.order-btn svg{flex-shrink:0;}

/* ADMIN ACTIONS */
.admin-actions{display:none;gap:6px;padding:10px 16px;border-top:1px solid var(--border);}
body.admin-mode .admin-actions{display:flex;}
.btn-edit,.btn-del{
  flex:1;display:inline-flex;align-items:center;justify-content:center;gap:4px;
  font-family:'DM Sans',sans-serif;font-size:.72rem;font-weight:700;
  padding:7px;border-radius:8px;cursor:pointer;border:1.5px solid;transition:all .2s;
}
.btn-edit{background:rgba(212,131,42,.1);border-color:rgba(212,131,42,.3);color:var(--amber);}
.btn-edit:hover{background:var(--amber);color:#fff;}
.btn-del{background:rgba(192,57,43,.08);border-color:rgba(192,57,43,.2);color:var(--red);}
.btn-del:hover{background:var(--red);color:#fff;}

/* ADD CARD */
.add-card{
  background:transparent;border:2px dashed var(--border);border-radius:16px;
  display:none;flex-direction:column;align-items:center;justify-content:center;
  gap:10px;cursor:pointer;transition:all .25s;min-height:280px;text-align:center;padding:24px;
}
body.admin-mode .add-card{display:flex;}
.add-card:hover{border-color:var(--amber);background:rgba(212,131,42,.05);}
.add-card-icon{font-size:2.5rem;opacity:.3;transition:opacity .2s;}
.add-card:hover .add-card-icon{opacity:1;}
.add-card-text{color:var(--muted);font-size:.88rem;font-weight:600;}

/* MODAL */
.overlay{position:fixed;inset:0;z-index:1000;background:rgba(44,26,14,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:16px;opacity:0;pointer-events:none;transition:opacity .3s;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--card);border-radius:20px;padding:32px;width:100%;max-width:520px;max-height:94vh;overflow-y:auto;transform:translateY(20px) scale(.97);transition:transform .3s;position:relative;}
.overlay.open .modal{transform:translateY(0) scale(1);}
.modal-close{position:absolute;top:16px;right:16px;width:30px;height:30px;border-radius:50%;background:var(--warm);border:1.5px solid var(--border);color:var(--muted);font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.modal-close:hover{background:var(--red);color:#fff;border-color:var(--red);}
.modal h2{font-family:'Fraunces',serif;font-size:1.4rem;font-weight:700;color:var(--brown);margin-bottom:4px;}
.modal-sub{color:var(--muted);font-size:.83rem;margin-bottom:24px;}

/* FORM */
.fg{margin-bottom:14px;}
.fg label{display:block;font-size:.72rem;font-weight:700;color:var(--brown);letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
.fg input,.fg textarea,.fg select{width:100%;background:var(--warm);border:1.5px solid var(--border);color:var(--brown);font-family:'DM Sans',sans-serif;font-size:.88rem;padding:11px 14px;border-radius:10px;outline:none;transition:border-color .2s;}
.fg input:focus,.fg textarea:focus,.fg select:focus{border-color:var(--amber);}
.fg textarea{resize:vertical;min-height:80px;}
.fg select option{background:var(--card);}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.btn-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px;}
.save-btn{background:var(--brown);color:#fff;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.9rem;padding:13px;border-radius:10px;cursor:pointer;transition:all .2s;}
.save-btn:hover{background:var(--brown2);}
.cancel-btn{background:var(--warm);border:1.5px solid var(--border);color:var(--muted);font-family:'DM Sans',sans-serif;font-weight:700;font-size:.9rem;padding:13px;border-radius:10px;cursor:pointer;transition:all .2s;}
.cancel-btn:hover{border-color:var(--brown);color:var(--brown);}

/* IMAGE UPLOAD */
.img-upload-area{
  width:100%;aspect-ratio:16/7;border:2px dashed var(--border);border-radius:10px;
  background:var(--warm);display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:8px;cursor:pointer;transition:all .2s;overflow:hidden;position:relative;
}
.img-upload-area:hover{border-color:var(--amber);background:rgba(212,131,42,.05);}
.img-upload-area img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0;}
.img-upload-area .upload-hint{font-size:.8rem;color:var(--muted);text-align:center;z-index:1;}
.img-upload-area .upload-icon{font-size:2rem;opacity:.4;z-index:1;}
#fileInput{display:none;}

/* LOGIN MODAL */
.login-lock{font-size:2.5rem;text-align:center;margin-bottom:12px;}
.pw-wrap{position:relative;}
.pw-wrap input{padding-right:44px;}
.pw-eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:1rem;padding:0;}
.login-err{color:var(--red);font-size:.78rem;font-weight:600;margin-top:8px;display:none;text-align:center;}
.login-err.show{display:block;}

/* DEL MODAL */
.del-icon{font-size:2.5rem;text-align:center;margin-bottom:10px;}
.del-btn{background:var(--red);color:#fff;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.9rem;padding:13px;border-radius:10px;cursor:pointer;transition:background .2s;}
.del-btn:hover{background:#a93226;}

/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--brown);color:#fff;font-weight:600;padding:11px 22px;border-radius:100px;z-index:9999;transition:transform .3s;font-size:.85rem;white-space:nowrap;pointer-events:none;}
.toast.show{transform:translateX(-50%) translateY(0);}
.toast.ok{background:var(--green);}
.toast.err{background:var(--red);}
.toast.warn{background:#d97706;}

/* EMPTY STATE */
.empty-state{text-align:center;padding:80px 24px;color:var(--muted);}
.empty-state .e-icon{font-size:3rem;margin-bottom:16px;opacity:.4;}
.empty-state p{font-size:.9rem;}

/* FOOTER */
footer{position:relative;z-index:1;text-align:center;padding:40px 24px;border-top:1px solid var(--border);background:var(--warm);color:var(--muted);font-size:.8rem;}
footer strong{color:var(--brown);}
footer a{color:var(--amber);text-decoration:none;}

/* WA FLOAT */
.wa-float{
  position:fixed;bottom:24px;right:24px;z-index:500;
  width:52px;height:52px;border-radius:50%;background:#25d366;
  border:none;color:#fff;font-size:1.5rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 20px rgba(37,211,102,.4);transition:all .2s;
}
.wa-float:hover{transform:scale(1.1);box-shadow:0 6px 28px rgba(37,211,102,.5);}

@keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
@keyframes cardIn{from{opacity:0;transform:translateY(14px) scale(.98);}to{opacity:1;transform:translateY(0) scale(1);}}
@media(max-width:560px){.frow,.btn-row{grid-template-columns:1fr;}.hero h1{font-size:2rem;}.stats-row{flex-wrap:wrap;}.stat-box{flex:1 1 45%;}}
</style>
</head>
<body>

<!-- HEADER -->
<header class="site-header">
  <a href="#" class="logo">
    <div class="logo-mark">✏️</div>
    <div>
      <div class="logo-text" id="siteName">Syakila ATK</div>
      <div class="logo-sub">Alat Tulis & Kantor</div>
    </div>
  </a>
  <div class="header-right">
    <div class="admin-pill" id="adminPill">
      🛡️ Admin
      <button class="logout-btn" id="logoutBtn">Keluar</button>
    </div>
    <button class="fab-login" id="fabLogin" title="Admin Login">🔑</button>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-tag">✨ Toko ATK Terpercaya</div>
  <h1>Semua Kebutuhan<br/><em>Alat Tulis</em> Kamu</h1>
  <p>Produk berkualitas untuk sekolah, kantor, dan kreativitasmu. Order langsung via WhatsApp!</p>
  <a href="#produk" class="hero-cta">
    Lihat Produk
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </a>
</section>

<!-- STATS -->
<div class="stats-row" id="statsRow"></div>

<!-- SEARCH -->
<div class="search-wrap">
  <span class="search-icon">🔍</span>
  <input class="search-input" id="searchInput" type="text" placeholder="Cari produk ATK..."/>
</div>

<!-- FILTER -->
<div class="filter-section" id="filterSection"></div>

<!-- PRODUK -->
<section class="products-section" id="produk">
  <div class="section-title">Semua Produk <span id="prodCount">0 item</span></div>
  <div class="grid" id="grid"></div>
</section>

<!-- OVERLAY: LOGIN -->
<div class="overlay" id="loginModal">
  <div class="modal" style="max-width:360px;">
    <div class="login-lock">🔐</div>
    <h2 style="text-align:center;">Login Admin</h2>
    <p class="modal-sub" style="text-align:center;">Masukkan password untuk mengelola produk.</p>
    <div class="fg">
      <label>Password</label>
      <div class="pw-wrap">
        <input type="password" id="pwInput" placeholder="••••••••"/>
        <button class="pw-eye" id="pwEye" type="button">👁️</button>
      </div>
    </div>
    <div class="login-err" id="loginErr">❌ Password salah, coba lagi.</div>
    <button class="save-btn" id="loginBtn" style="width:100%;margin-top:14px;">🔓 Masuk</button>
  </div>
</div>

<!-- OVERLAY: PRODUK (tambah/edit) -->
<div class="overlay" id="prodModal">
  <div class="modal">
    <button class="modal-close" id="closeProdModal">✕</button>
    <h2 id="prodModalTitle">➕ Tambah Produk</h2>
    <p class="modal-sub" id="prodModalSub">Isi semua data produk ATK.</p>
    <input type="hidden" id="fId"/>

    <!-- Gambar -->
    <div class="fg">
      <label>Foto Produk</label>
      <div class="img-upload-area" id="imgUploadArea">
        <div class="upload-icon">📷</div>
        <div class="upload-hint">Klik untuk upload foto<br/><small>JPG, PNG, WEBP — maks 5MB</small></div>
        <img id="imgPreview" style="display:none;"/>
      </div>
      <input type="file" id="fileInput" accept="image/*"/>
    </div>

    <div class="frow">
      <div class="fg"><label>Nama Produk *</label><input type="text" id="fName" placeholder="Pensil 2B Faber-Castell"/></div>
      <div class="fg"><label>Emoji Ikon</label><input type="text" id="fIcon" placeholder="✏️" maxlength="2"/></div>
    </div>
    <div class="frow">
      <div class="fg"><label>Kategori</label>
        <select id="fCat">
          <option value="Pensil & Pena">Pensil & Pena</option>
          <option value="Buku & Kertas">Buku & Kertas</option>
          <option value="Alat Gambar">Alat Gambar</option>
          <option value="Aksesori Meja">Aksesori Meja</option>
          <option value="Perlengkapan Kantor">Perlengkapan Kantor</option>
          <option value="Lainnya">Lainnya</option>
        </select>
      </div>
      <div class="fg"><label>Badge Label</label><input type="text" id="fBadge" placeholder="BARU / PROMO / BEST SELLER"/></div>
    </div>
    <div class="fg"><label>Deskripsi *</label><textarea id="fDesc" placeholder="Deskripsi produk..."></textarea></div>
    <div class="frow">
      <div class="fg"><label>Harga (Rp) *</label><input type="number" id="fPrice" placeholder="5000"/></div>
      <div class="fg"><label>Stok (pcs)</label><input type="number" id="fStock" placeholder="50"/></div>
    </div>
    <div class="fg"><label>Fitur / Keunggulan (pisah koma)</label><input type="text" id="fFeats" placeholder="Tahan air, Warna cerah, Anti luntur"/></div>
    <div class="fg"><label>No. WhatsApp Penjual</label><input type="text" id="fWa" placeholder="6281234567890"/></div>
    <div class="btn-row">
      <button class="cancel-btn" id="cancelProd">Batal</button>
      <button class="save-btn" id="saveProd">💾 Simpan</button>
    </div>
  </div>
</div>

<!-- OVERLAY: HAPUS -->
<div class="overlay" id="delModal">
