      description:'Set highlighter 4 warna cerah yang tidak merusak tinta printer maupun tinta pulpen.',
      features:['4 warna','Tinta cerah','Tidak merusak teks','Chisel tip'],
      price:28000, stock:45, badge:'PROMO',
