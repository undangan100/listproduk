      description:'Pensil berkualitas tinggi dengan tingkat kegelapan 2B, cocok untuk menulis, sketsa, dan ujian.',
      features:['Grade 2B','Isi dapat diganti','Anti patah','Lembut di kertas'],
      price:3500, stock:120, badge:'POPULER',
      img:'', wa:'6281234567890',
      orderMessage:'Halo kak, saya mau order Pensil 2B Faber-Castell. Masih ada stok?'
    },
    {
      id:2, name:'Pulpen Pilot G2 0.5mm', icon:'🖊️', category:'Pensil & Pena',
      description:'Pulpen gel premium dengan tinta smooth, tidak bocor, dan hasil tulisan rapi dan elegan.',
      features:['Tinta gel','0.5mm fine tip','Anti bocor','Grip ergonomis'],
      price:12000, stock:85, badge:'BEST SELLER',
      img:'', wa:'6281234567890',
      orderMessage:'Halo kak, saya mau order Pulpen Pilot G2. Masih ada stok?'
    },
    {
