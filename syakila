<div class="toast" id="toast"></div>

<script>
// ══════════════════════════════════════════
//  ⚙️  CONFIG
// ══════════════════════════════════════════
var CONFIG = {
  storeName: 'Syakila ATK Store',
  waDefault: '6281234567890', // WhatsApp default penjual
  adminPassword: 'syakila',   // ← PASSWORD ADMIN
  categories: ['Semua','Pensil & Pena','Buku & Kertas','Alat Gambar','Aksesori Meja','Perlengkapan Kantor','Lainnya'],
  defaultProducts: [
    {
